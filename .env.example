# Copy to .env and fill in values before running docker compose up.

REDMINE_URL=https://redmine.example.com
REDMINE_API_KEY=your_redmine_api_key

# Leave empty to disable webhook signature verification.
GITEA_WEBHOOK_SECRET=your_gitea_webhook_secret

# How often (seconds) to re-sync all repos regardless of webhook activity.
RECONCILE_INTERVAL=3600

# How long (seconds) to cache the Redmine repo list.
CACHE_TTL=300
